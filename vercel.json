{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/learn/what-is-cost-segregation", "destination": "/learn/what-is-cost-segregation.html" },
    { "source": "/learn/cost-segregation-rental-property", "destination": "/learn/cost-segregation-rental-property.html" },
    { "source": "/learn/cost-segregation-study-cost", "destination": "/learn/cost-segregation-study-cost.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" }
  ],
  "headers": [
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" }
      ]
    },
    {
      "source": "/learn/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    }
  ]
}
